# Copy this file to .env and fill in your values. Never commit .env to git.

# Mapbox public token — https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_PUBLIC_TOKEN=pk.your_token_here

# Vercel API key (server-side only, never expose in the frontend)
VERCEL_API_KEY=vck_vercel_api_key_here

# Base URL of your Vercel backend (e.g. https://campusos-api.vercel.app)
EXPO_PUBLIC_API_BASE_URL=https://your-project.vercel.app
